APP_NAME=Tourvaa Backend
APP_ENV=development
APP_DEBUG=true

DATABASE_URL=mysql+pymysql://USER:PASSWORD@HOST:3306/DATABASE_NAME

JWT_SECRET_KEY=replace_with_a_strong_random_secret_32_chars_minimum
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Per-portal JWT secrets — leave blank to fall back to JWT_SECRET_KEY
SUPPLIER_JWT_SECRET_KEY=
AGENT_JWT_SECRET_KEY=
CUSTOMER_JWT_SECRET_KEY=
ADMIN_JWT_SECRET_KEY=
REQUIRE_EMAIL_VERIFICATION=false
EMAIL_VERIFICATION_EXPIRE_MINUTES=1440

API_BASE_URL=http://127.0.0.1:8000
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000
MOBILE_DEEP_LINK_URL=tourvaa://reset-password
STORAGE_ROOT=storage

SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_EMAIL=admin@tourvaa.com
SUPER_ADMIN_PASSWORD=change_this_before_handover
SUPER_ADMIN_RESET_PASSWORD_ON_STARTUP=false

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=user@example.com
SMTP_PASSWORD=replace_with_smtp_password
SMTP_FROM_NAME=Tourvaa

ANTHROPIC_API_KEY=

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY_FILE=vapid_private.pem
VAPID_MAILTO=mailto:admin@tourvaa.com

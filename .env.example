APP_NAME=Tourvaa Backend
APP_ENV=development
APP_DEBUG=true

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=mysql+pymysql://USER:PASSWORD@localhost:3306/tourvaa_db

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your-random-hex-secret-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Per-portal JWT secrets (leave blank to fall back to JWT_SECRET_KEY)
SUPPLIER_JWT_SECRET_KEY=
AGENT_JWT_SECRET_KEY=
CUSTOMER_JWT_SECRET_KEY=
ADMIN_JWT_SECRET_KEY=

# ─── App URLs ─────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
API_BASE_URL=http://127.0.0.1:8000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
MOBILE_DEEP_LINK_URL=tourvaa://reset-password

# ─── Storage ──────────────────────────────────────────────────────────────────
STORAGE_ROOT=storage

# ─── ImageKit (file/image storage + CDN) ──────────────────────────────────────
# Get these from https://imagekit.io/dashboard/developer/api-keys
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id

# ─── Super Admin ──────────────────────────────────────────────────────────────
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=ChangeMe@123
SUPER_ADMIN_RESET_PASSWORD_ON_STARTUP=false

# ─── Email Verification ───────────────────────────────────────────────────────
REQUIRE_EMAIL_VERIFICATION=false
EMAIL_VERIFICATION_EXPIRE_MINUTES=1440

# ─── SMTP ─────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USERNAME=no-reply@example.com
SMTP_USER=no-reply@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_NAME=Tourvaa

# ─── AI / Chatbot ─────────────────────────────────────────────────────────────
# Get your key from https://console.anthropic.com
ANTHROPIC_API_KEY=

# ─── Geo API ──────────────────────────────────────────────────────────────────
# Get free key from https://countrystatecity.in
COUNTRY_STATE_CITY_API_KEY=

# ─── Stripe ───────────────────────────────────────────────────────────────────
# After filling these, run: python seed_stripe.py  to store them encrypted in DB
# STRIPE_WEBHOOK_SECRET: Stripe Dashboard → Developers → Webhooks → Signing secret
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── PayPal ───────────────────────────────────────────────────────────────────
# After filling these, run: python seed_paypal.py
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# NEVER change this after first use - existing encrypted DB values will break.
SETTINGS_ENCRYPTION_KEY=your-random-hex-64-chars

# ─── Redis (optional) ─────────────────────────────────────────────────────────
# Leave blank to use in-memory rate limiting (not suitable for multi-worker prod)
REDIS_URL=

# ─── Web Push (VAPID) ─────────────────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY_FILE=vapid_private.pem
VAPID_MAILTO=mailto:your@email.com
